# .env.example
# Copy this file to .env and fill in your API keys

# Google Cloud API
GOOGLE_TRANSLATE_API_KEY=your_google_cloud_api_key_here
GOOGLE_TTS_API_KEY=your_google_cloud_api_key_here

# FFmpeg paths (optional, if not in PATH)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Logging
LOG_LEVEL=INFO

# Processing settings
WHISPER_MODEL=base
DEFAULT_VIDEO_QUALITY=720
DEFAULT_AUDIO_QUALITY=128
